# Optional — enables one-click contact import (set in Vercel or paste in Settings)

# Google: Cloud Console → APIs → People API → OAuth client (Web)
# Authorized JavaScript origin: https://your-domain.vercel.app
VITE_GOOGLE_CLIENT_ID=

# Microsoft: Azure Portal → App registrations → SPA redirect URI = your domain
# API permissions: Contacts.Read, User.Read
VITE_MICROSOFT_CLIENT_ID=
